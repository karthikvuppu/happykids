# Database — use PostgreSQL on Render (auto-filled by render.yaml)
DATABASE_URL=postgresql://user:password@localhost:5432/happykids

# Security — generate a strong random key for production
SECRET_KEY=your-strong-random-secret-key-here

# CORS — set to your Render frontend URL
FRONTEND_URL=https://happykids-frontend.onrender.com

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
